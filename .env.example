# ─── Database ─────────────────────────────────────────────────────────────────
# Connection string do PostgreSQL.
# Em local: usa o container Docker "postgres" da rede interna.
# Em Railway: cole a DATABASE_URL gerada pelo plugin PostgreSQL do Railway.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# (Usado apenas localmente pelo docker-compose para subir o container postgres)
POSTGRES_USER=pguser
POSTGRES_PASSWORD=pgpassword
POSTGRES_DB=childrendb

# ─── Application ──────────────────────────────────────────────────────────────
PORT=3001

# Segredo de assinatura do JWT — gere com: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand

# Origens permitidas no CORS (separadas por vírgula para múltiplas).
# Em local: http://localhost:3000
# Em produção: URL pública do frontend no Vercel
CORS_ORIGIN=http://localhost:3000

# ─── Initial admin user (seed) ────────────────────────────────────────────────
ADMIN_EMAIL=tecnico@prefeitura.rio
ADMIN_PASSWORD=CHANGE_ME_strong_password

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
# URL da API acessível pelo browser do usuário (pública)
NEXT_PUBLIC_API_URL=http://localhost:3001

# URL da API acessível pelo servidor Next.js (interna Docker ou Railway)
# Em local: http://backend:3001  (nome do serviço Docker)
# Em Vercel: URL pública do backend no Railway (ex: https://backend-xxx.railway.app)
BACKEND_URL=http://backend:3001
