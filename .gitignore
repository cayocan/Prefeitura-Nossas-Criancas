# Git ignore para projeto com backend (Node + Python + Docker)

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp/
.pnp.js
.cache/

# Logs
logs/
*.log
*.log.*
pids/
*.pid
tmp/
temp/

# Environment
# .env is intentionally committed for this exercise so evaluators can run the
# project without manual setup. In a real project, .env would be listed here
# and secrets would be managed via a dedicated secrets manager.
# .env
.env.*.local
!.env.example

# Build / output
dist/
build/
out/
coverage/
.nyc_output/
coverage-final.json
*.tgz

# Python
venv/
.venv/
env/
ENV/
__pycache__/
*.py[cod]
*$py.class
pip-wheel-metadata/
*.egg-info/
.pytest_cache/
.mypy_cache/
.pyre/
.tox/
htmlcov/

# Docker
docker-compose.override.yml

# VS Code
.vscode/

# IDEs
.idea/
*.sublime-workspace
*.sublime-project

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Temp / swap
*~
*.swp
*.swo
*.tmp
*.bak
*.orig
*.rej

# Keys and secrets
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.jks
credentials.json
secrets.env

# Compiled/binary
*.exe
*.dll
*.so
*.dylib
*.o
